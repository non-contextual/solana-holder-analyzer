# Helius API key — https://dev.helius.xyz/
HELIUS_API_KEY=your_helius_api_key_here

# OKX Web3 API keys (optional — needed for total portfolio value column)
# https://web3.okx.com/onchain-os/dev-portal
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# HTTP proxy (optional — for mainland China to reach OKX)
# HTTPS_PROXY=http://127.0.0.1:10808

# Server port (default: 3456)
# PORT=3456
